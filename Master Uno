#include <AFMotor.h>
#include <Servo.h>
#include <Wire.h> // I2C Haberleşme Kütüphanesi

// --- 4 ADET DC MOTOR ---
AF_DCMotor motor1(1);
AF_DCMotor motor2(2);
AF_DCMotor motor3(3);
AF_DCMotor motor4(4);

// --- 2 ADET BELDEN KIRMA SERVOSU ---
Servo servo1; 
Servo servo2; 

String command = "";
bool isCommandStarted = false;
bool isSystemActive = true; 

// --- I2C (ZAMANLAMA) DEĞİŞKENLERİ ---
unsigned long previousMillis = 0;
const long interval = 500; // Yarım saniyede bir Slave Uno'yu sorgula

void setup() {
  // Artık ESP32 ile donanımsal porttan (Pin 0 ve 1) haberleşiyoruz.
  Serial.begin(9600);
  
  // Master olarak I2C veri yoluna katıl (A4=SDA, A5=SCL)
  Wire.begin(); 

  servo1.attach(10);
  servo2.attach(9);
  
  centerServos();
  setMotorSpeeds(100);
  stopMotors(); 
}

void loop() {
  // 1. GÖREV: ESP32'den gelen Sürüş Komutlarını Oku
  while (Serial.available() > 0) {
    char c = Serial.read();
    if (c == '<') {
      isCommandStarted = true;
      command = ""; 
    } else if (c == '>') {
      isCommandStarted = false;
      executeCommand(command); 
    } else if (isCommandStarted) {
      command += c; 
    }
  }

  // 2. GÖREV: Arka planda zamanı takip et ve Slave Uno'dan veri iste
  unsigned long currentMillis = millis();
  if (currentMillis - previousMillis >= interval) {
    previousMillis = currentMillis;
    
    // Sistem uykuda değilse sensör verilerini çek
    if (isSystemActive) {
      fetchSensorDataFromSlave();
    }
  }
}

// --- I2C SENSÖR OKUMA VE ESP32'YE İLETME ---
void fetchSensorDataFromSlave() {
  // Slave Uno'nun I2C adresini 8 olarak belirledik. Ondan 2 byte veri istiyoruz.
  Wire.requestFrom(8, 2); 

  if (Wire.available() == 2) {
    byte pirValue = Wire.read();  
    byte distValue = Wire.read(); 

    // Gelen ham verileri ESP32'nin anlayacağı formata çevirip donanımsal porta yaz
    Serial.print("PIR:");
    Serial.println(pirValue);
    
    Serial.print("DIST:");
    Serial.println(distValue);
  }
}

// --- KOMUT İŞLETİM MERKEZİ ---
void executeCommand(String cmd) {
  if (cmd == "PWR1") {
    isSystemActive = true;
    return;
  } 
  else if (cmd == "PWR0" || cmd == "EMG") {
    isSystemActive = false;
    stopMotors(); 
    return;
  }

  if (!isSystemActive) return;

  if (cmd == "F") moveForward();
  else if (cmd == "B") moveBackward();
  else if (cmd == "S") stopMotors();
  else if (cmd == "SL") bendLeft();
  else if (cmd == "SR") bendRight();
  else if (cmd == "SC") centerServos();
}

// --- DC MOTOR SÜRÜŞ FONKSİYONLARI ---
void moveForward() { motor1.run(FORWARD); motor2.run(FORWARD); motor3.run(FORWARD); motor4.run(FORWARD); }
void moveBackward() { motor1.run(BACKWARD); motor2.run(BACKWARD); motor3.run(BACKWARD); motor4.run(BACKWARD); }
void stopMotors() { motor1.run(RELEASE); motor2.run(RELEASE); motor3.run(RELEASE); motor4.run(RELEASE); }
void setMotorSpeeds(int speed) { motor1.setSpeed(speed); motor2.setSpeed(speed); motor3.setSpeed(speed); motor4.setSpeed(speed); }

// --- SERVO (BELDEN KIRMA) FONKSİYONLARI ---
void bendLeft() { servo1.write(45); servo2.write(45);  }
void bendRight() { servo1.write(135); servo2.write(135);  }
void centerServos() { servo1.write(90); servo2.write(90); }
